# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here   # Never expose to browser

# ─── Razorpay ────────────────────────────────────────────────────────────────
# Get these from: https://dashboard.razorpay.com → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here   # Never expose to browser
# Razorpay webhook secret — set in Razorpay dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ─── Railway worker ──────────────────────────────────────────────────────────
# The engine (Playwright extraction) runs on Railway, not Vercel.
# Set this once the Railway service is deployed.
RAILWAY_WORKER_URL=https://your-shoprift-worker.railway.app

# ─── Shopify App ─────────────────────────────────────────────────────────────
# Get from: partners.shopify.com → Apps → [your app] → App setup
SHOPIFY_API_KEY=your_shopify_client_id_here
SHOPIFY_API_SECRET=your_shopify_client_secret_here
# The public URL of this app (no trailing slash). Use ngrok URL for local dev.
SHOPIFY_APP_URL=https://your-shoprift-app.vercel.app
# Comma-separated OAuth scopes (must match what's set in Partner dashboard)
SHOPIFY_SCOPES=write_products,read_products,write_product_listings

# ─── Optional ─────────────────────────────────────────────────────────────────
# NODE_ENV is set automatically by Next.js. Do not set it here.

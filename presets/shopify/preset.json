{
  "platform": "shopify",
  "format": "csv",
  "name": "Shopify Product Import",
  "knowledge_file": "./SHOPIFY.md",
  "verified_fixture": "./fixtures/kiwiishop.expected.csv",
  "last_verified": "2026-05-12",
  "columns": [
    { "name": "Handle",                                    "required": true,  "applies_to": ["anchor", "variant", "image_only"], "source": "computed:slugify(product.name)" },
    { "name": "Title",                                     "required": true,  "applies_to": ["anchor"],                          "source": "product.name" },
    { "name": "Body (HTML)",                               "required": false, "applies_to": ["anchor"],                          "source": "static:" },
    { "name": "Vendor",                                    "required": true,  "applies_to": ["anchor"],                          "source": "store_meta.name" },
    { "name": "Product Category",                          "required": false, "applies_to": ["anchor"],                          "source": "static:" },
    { "name": "Type",                                      "required": false, "applies_to": ["anchor"],                          "source": "computed:category_if_categorized" },
    { "name": "Tags",                                      "required": false, "applies_to": ["anchor"],                          "source": "computed:tags_with_category" },
    { "name": "Published",                                 "required": true,  "applies_to": ["anchor"],                          "source": "static:TRUE" },
    { "name": "Option1 Name",                              "required": true,  "applies_to": ["anchor"],                          "source": "computed:option1_name" },
    { "name": "Option1 Value",                             "required": true,  "applies_to": ["anchor", "variant"],               "source": "computed:option1_value" },
    { "name": "Option1 Linked To",                         "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Option2 Name",                              "required": false, "applies_to": ["anchor"],                          "source": "computed:option2_name" },
    { "name": "Option2 Value",                             "required": false, "applies_to": ["anchor", "variant"],               "source": "computed:option2_value" },
    { "name": "Option2 Linked To",                         "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Option3 Name",                              "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Option3 Value",                             "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Option3 Linked To",                         "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Variant SKU",                               "required": false, "applies_to": ["anchor", "variant"],               "source": "static:" },
    { "name": "Variant Grams",                             "required": true,  "applies_to": ["anchor", "variant"],               "source": "static:0" },
    { "name": "Variant Inventory Tracker",                 "required": true,  "applies_to": ["anchor", "variant"],               "source": "static:shopify" },
    { "name": "Variant Inventory Qty",                     "required": true,  "applies_to": ["anchor", "variant"],               "source": "static:1" },
    { "name": "Variant Inventory Policy",                  "required": true,  "applies_to": ["anchor", "variant"],               "source": "static:deny" },
    { "name": "Variant Fulfillment Service",               "required": true,  "applies_to": ["anchor", "variant"],               "source": "static:manual" },
    { "name": "Variant Price",                             "required": true,  "applies_to": ["anchor", "variant"],               "source": "product.price" },
    { "name": "Variant Compare At Price",                  "required": false, "applies_to": ["anchor", "variant"],               "source": "product.original_price" },
    { "name": "Variant Requires Shipping",                 "required": true,  "applies_to": ["anchor", "variant"],               "source": "static:TRUE" },
    { "name": "Variant Taxable",                           "required": true,  "applies_to": ["anchor", "variant"],               "source": "static:TRUE" },
    { "name": "Variant Barcode",                           "required": false, "applies_to": ["anchor", "variant"],               "source": "static:" },
    { "name": "Image Src",                                 "required": false, "applies_to": ["anchor", "variant", "image_only"], "source": "computed:image_src" },
    { "name": "Image Position",                            "required": false, "applies_to": ["anchor", "variant", "image_only"], "source": "computed:image_position" },
    { "name": "Image Alt Text",                            "required": false, "applies_to": ["anchor"],                          "source": "product.name" },
    { "name": "Gift Card",                                 "required": true,  "applies_to": ["anchor"],                          "source": "static:FALSE" },
    { "name": "SEO Title",                                 "required": false, "applies_to": ["anchor"],                          "source": "static:" },
    { "name": "SEO Description",                           "required": false, "applies_to": ["anchor"],                          "source": "static:" },
    { "name": "Google Shopping / Google Product Category", "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Google Shopping / Gender",                  "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Google Shopping / Age Group",               "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Google Shopping / MPN",                     "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Google Shopping / Condition",               "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Google Shopping / Custom Product",          "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Variant Image",                             "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Variant Weight Unit",                       "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Variant Tax Code",                          "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Cost per item",                             "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Included / India",                          "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Price / India",                             "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Compare At Price / India",                  "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Included / International",                  "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Price / International",                     "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Compare At Price / International",          "required": false, "applies_to": [],                                  "source": "static:" },
    { "name": "Status",                                    "required": true,  "applies_to": ["anchor"],                          "source": "static:active" }
  ],
  "row_strategy": {
    "rows_per_product": "max(variants, images)",
    "row_types": {
      "anchor": "row 1 — all product-level fields populated",
      "variant": "rows 2..V — variant-specific fields, when variants exist",
      "image_only": "rows V+1..max — handle + image only"
    }
  },
  "field_defaults": {
    "Published": "TRUE",
    "Status": "active",
    "Gift Card": "FALSE",
    "Variant Inventory Tracker": "shopify",
    "Variant Inventory Qty": "1",
    "Variant Inventory Policy": "deny",
    "Variant Fulfillment Service": "manual",
    "Variant Requires Shipping": "TRUE",
    "Variant Taxable": "TRUE",
    "Variant Grams": "0"
  },
  "tag_convention": {
    "source": "product.category",
    "fallback": "product.tags",
    "format": "category-first-comma-separated",
    "uncategorized_behavior": "blank",
    "example": "Hair Accessories, sale"
  }
}

{
  "name": "Shopify Product Import",
  "version": "1.0",
  "row_strategy": "one_row_per_variant",
  "columns": [
    { "header": "Handle",                        "field": "name",            "transform": "slugify" },
    { "header": "Title",                         "field": "name" },
    { "header": "Body (HTML)",                   "field": "description",     "fallback": "" },
    { "header": "Vendor",                        "field": "store_name" },
    { "header": "Type",                          "field": "category",        "fallback": "" },
    { "header": "Tags",                          "field": "tags",            "transform": "join_comma" },
    { "header": "Published",                     "static": "TRUE" },
    { "header": "Option1 Name",                  "static": "Color" },
    { "header": "Option1 Value",                 "field": "variant_color" },
    { "header": "Option2 Name",                  "static": "Size" },
    { "header": "Option2 Value",                 "field": "variant_size" },
    { "header": "Variant SKU",                   "static": "" },
    { "header": "Variant Price",                 "field": "price" },
    { "header": "Variant Compare At Price",      "field": "original_price",  "fallback": "" },
    { "header": "Variant Inventory Tracker",     "static": "shopify" },
    { "header": "Variant Inventory Qty",         "static": "10" },
    { "header": "Variant Inventory Policy",      "static": "deny" },
    { "header": "Variant Fulfillment Service",   "static": "manual" },
    { "header": "Variant Requires Shipping",     "static": "TRUE" },
    { "header": "Variant Taxable",               "static": "TRUE" },
    { "header": "Image Src",                     "field": "image_url_current" },
    { "header": "Image Position",                "field": "image_position" },
    { "header": "Image Alt Text",                "field": "name" },
    { "header": "Status",                        "static": "active" }
  ]
}

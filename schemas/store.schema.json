{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "shoprift-store-schema-v1",
  "title": "Shoprift Store Import Schema",
  "description": "Canonical schema for store data extracted by Shoprift and imported into [App Name]. Version 1.0.0.",
  "type": "object",
  "required": ["store_meta", "products", "categories", "migration_flags", "scrape_meta"],
  "properties": {
    "store_meta": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "instagram": { "type": ["string", "null"] },
        "contact": {
          "type": "object",
          "properties": {
            "phone": { "type": ["string", "null"] },
            "email": { "type": ["string", "null"] },
            "whatsapp": { "type": ["string", "null"] },
            "support_note": { "type": ["string", "null"] }
          }
        },
        "location": { "type": ["string", "null"] },
        "shipping": {
          "type": "object",
          "properties": {
            "processing_time": { "type": ["string", "null"] },
            "delivery_time": { "type": ["string", "null"] },
            "shipping_regions": { "type": ["string", "null"] },
            "minimum_order_value": { "type": ["number", "null"] },
            "shipping_charges": { "type": ["number", "null"] },
            "ships_within_days": { "type": ["number", "null"] }
          }
        },
        "payment_methods": {
          "type": "array",
          "items": { "type": "string" }
        },
        "policies": {
          "type": "object",
          "properties": {
            "cancellations_accepted": { "type": "boolean" },
            "returns_accepted": { "type": "boolean" },
            "exchanges_accepted": { "type": "boolean" },
            "damage_claim_note": { "type": ["string", "null"] }
          }
        }
      }
    },
    "products": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "price", "currency", "stock_status", "images_cdn", "product_url", "selected_for_import"],
        "properties": {
          "id": { "type": "number" },
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": ["string", "null"] },
          "needs_description": { "type": "boolean" },
          "price": { "type": "number", "minimum": 0 },
          "original_price": { "type": ["number", "null"] },
          "discount_percentage": { "type": ["number", "null"] },
          "currency": { "type": "string", "enum": ["INR"] },
          "category": { "type": ["string", "null"] },
          "is_uncategorized": { "type": "boolean" },
          "variants": {
            "type": "object",
            "properties": {
              "sizes": { "type": "array", "items": { "type": "string" } },
              "colors": { "type": "array", "items": { "type": "string" } },
              "other": { "type": "array", "items": { "type": "string" } }
            }
          },
          "stock_status": { "type": "string", "enum": ["in_stock", "out_of_stock", "unknown"] },
          "images_cdn": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "images_local": { "type": "array", "items": { "type": "string" } },
          "images_failed": { "type": "array", "items": { "type": "string" } },
          "product_url": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "selected_for_import": { "type": "boolean" }
        }
      }
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "url", "product_count", "slug"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "url": { "type": "string" },
          "product_count": { "type": "number" },
          "slug": { "type": "string" }
        }
      }
    },
    "migration_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "severity", "message", "action_required"],
        "properties": {
          "type": { "type": "string" },
          "severity": { "type": "string", "enum": ["warning", "info"] },
          "product_id": { "type": ["number", "null"] },
          "message": { "type": "string" },
          "action_required": { "type": "string" }
        }
      }
    },
    "scrape_meta": {
      "type": "object",
      "required": ["source_url", "shoprift_version", "timestamp"],
      "properties": {
        "source_url": { "type": "string" },
        "shoprift_version": { "type": "string" },
        "timestamp": { "type": "string" },
        "duration_seconds": { "type": "number" },
        "total_products_found": { "type": "number" },
        "total_products_selected": { "type": "number" },
        "total_categories": { "type": "number" },
        "total_images_found": { "type": "number" },
        "total_images_downloaded": { "type": "number" },
        "total_images_failed": { "type": "number" },
        "verification_method": { "type": "string", "enum": ["instagram_story", "dm2buy_product"] },
        "confidence_scores": {
          "type": "object",
          "properties": {
            "store_meta": { "type": "number", "minimum": 0, "maximum": 100 },
            "products": { "type": "number", "minimum": 0, "maximum": 100 },
            "categories": { "type": "number", "minimum": 0, "maximum": 100 }
          }
        },
        "migration_flag_count": { "type": "number" },
        "notes": { "type": ["string", "null"] }
      }
    }
  }
}
